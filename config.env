# Feed RAM refresh configuration.
# Copy this file to config.env in the service directory for local overrides.

DB_NAME=deedspot
MYSQL_BIN=mysql
MYSQL_ARGS="--defaults-extra-file=/opt/pa_services/feed-ram-refresh/mysql.cnf"

FEED_RAM_LOG_DIR=logs

FEED_RAM_CAMPAIGN_ACTIONS_RECENT_DAYS=200
FEED_RAM_CAMPAIGN_ACTIONS_TARGET_BYTES=134217728
FEED_RAM_CAMPAIGN_ACTIONS_SAFETY_PCT=90
FEED_RAM_CAMPAIGN_ACTIONS_ESTIMATED_BYTES_PER_ROW=150
FEED_RAM_CAMPAIGN_ACTIONS_CRON="*/10 * * * *"

FEED_RAM_HYDRATED_ACTIONS_RECENT_DAYS=30
FEED_RAM_HYDRATED_ACTIONS_TARGET_BYTES=268435456
FEED_RAM_HYDRATED_ACTIONS_SAFETY_PCT=90
FEED_RAM_HYDRATED_ACTIONS_ESTIMATED_BYTES_PER_ROW=65536
FEED_RAM_HYDRATED_ACTIONS_CRON="*/10 * * * *"
