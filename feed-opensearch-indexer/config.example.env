# Feed OpenSearch indexer configuration.
# Copy to config.env or run ./feed_opensearch_ctl.sh init-config.

DB_ENGINE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=pa_indexer
MYSQL_PASSWORD='Pa_Indexer_2026!ChangeMe'
MYSQL_DATABASE=pa_opensearch_indexer
MYSQL_APP_HOST=localhost
MYSQL_BIN=mysql
MYSQL_ADMIN_BIN=sudo

# Optional admin mysql command/arguments used by db:install/db:schema.
# Examples:
#   MYSQL_ADMIN_BIN=mysql
#   MYSQL_ADMIN_ARGS="-u root -p"
#   MYSQL_ADMIN_BIN=sudo
#   MYSQL_ADMIN_ARGS=mysql
MYSQL_ADMIN_ARGS=mysql

SERVICE_USER=pa_indexer
SERVICE_GROUP=pa_indexer

# setup-venv creates this path.
PYTHON_BIN=/opt/pa_services/feed-opensearch-indexer/venv/bin/python

LOG_LEVEL=INFO
LOG_FILE=logs/pa_opensearch_indexer.log

DAEMON_POLL_INTERVAL_SECONDS=2
DAEMON_BATCH_DELAY_SECONDS=0
DAEMON_BATCH_SIZE=100
DAEMON_CLAIM_STRATEGY=simple
DAEMON_RETRY_DELAY_SECONDS=0

DB_RETRY_ATTEMPTS=3
DB_RETRY_BASE_DELAY_SECONDS=0.1
DB_RETRY_MAX_DELAY_SECONDS=2

REAPER_POLL_INTERVAL_SECONDS=60
REAPER_BATCH_DELAY_SECONDS=0.5
REAPER_BATCH_SIZE=1000
REAPER_STALE_SECONDS=600
REAPER_RELEASE_DELAY_SECONDS=600

# Number of systemd template instances managed by services:* commands.
WORKER_COUNT=1
REAPER_COUNT=1
